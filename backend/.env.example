# Server port.
# Local dev commonly uses 8080; Alibaba Cloud production currently uses 9528.
PORT=8080
HOST=127.0.0.1

# --- Provider 0: HivisionIDPhotos ---
# Professional ID photo processing: face detection, crop, matting, background fill.
HIVISION_URL=

# --- Provider 1: Alibaba Cloud Bailian / Qwen / Wanx ---
# Used for cosmetic edit pass and fallback image generation.
BAILIAN_API_KEY=

# --- Optional 3D provider ---
TRIPO_API_KEY=
TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi

# App key authentication
APP_API_KEY=
REQUIRE_APP_KEY=false

# Referral code signing. Store production value in Alibaba Cloud KMS Secrets Manager.
REFERRAL_HMAC_SECRET=

# Daily budget circuit breaker
DAILY_BUDGET=5000
