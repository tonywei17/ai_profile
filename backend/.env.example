# Server port
PORT=8080

# --- Provider 1: Gemini direct API (via Secret Manager in prod) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_ENDPOINT_PRO=https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-image-preview:generateContent
GEMINI_ENDPOINT_FREE=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image:generateContent

# --- Provider 2: OpenRouter (via Secret Manager in prod) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Provider 3: OpenRouter (separate key, via env) ---
OPENROUTER_API_KEY_ENV=

# --- Provider 4: OpenAI compatible (via env) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# App key authentication
APP_API_KEY=
REQUIRE_APP_KEY=false

# Daily budget circuit breaker
DAILY_BUDGET=5000
